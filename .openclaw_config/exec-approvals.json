{
  "version": 1,
  "socket": {
    "path": "/root/.openclaw/exec-approvals.sock",
    "token": "REPLACEME_WITH_SESSION_TOKEN"
  },
  "defaults": {},
  "agents": {
    "*": {
      "allowlist": [
        { "pattern": "/repo/**" },
        { "pattern": "/usr/bin/dotnet" },
        { "pattern": "/usr/local/bin/godot" },
        { "pattern": "/usr/bin/curl" },
        { "pattern": "/usr/bin/git" },
        { "pattern": "/usr/bin/apt-get" },
        { "pattern": "/usr/bin/npm" },
        { "pattern": "/usr/bin/env" },
        { "pattern": "/usr/local/bin/agy" }
      ]
    }
  }
}
