# ⚠️ Esta key la usa SOLO Chappie (OpenClaw) con gemini-2.5-flash.
# DEBE venir de un proyecto de Google Cloud / AI Studio SIN billing activado (free tier).
# Si activas billing, vuelve a cobrar. Sin billing, al topar el límite solo da 429 (gratis).
# El coding pesado NO usa esta key: usa el login OAuth del Gemini CLI (free tier aparte).
GEMINI_API_KEY=your_free_tier_gemini_api_key_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
OPENCLAW_PASSWORD=sandbox

# --- Git: para que Chappie pueda commitear/pushear a GitHub desde el contenedor ---
# PAT de GitHub con permiso de escritura sobre el repo night-coding. Idealmente un
# fine-grained token limitado SOLO a Gozhack/night-coding (Contents: Read/Write).
# Sin esto, Chappie puede commitear local pero NO pushear (y no se dispara el deploy).
GITHUB_TOKEN=ghp_your_personal_access_token_here
# Identidad con la que el bot firma sus commits (opcional, tiene defaults).
GIT_USER_NAME=Chappie
GIT_USER_EMAIL=chappie@night-coding.local
