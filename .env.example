# --- CEREBRO: Claude-Haiku (orquestador) vía API de Anthropic ---
# ⚠️ ESTA key SÍ factura por token. Sácala de console.anthropic.com (formato sk-ant-...)
# y PONLE UN LÍMITE DE GASTO duro en la consola antes de soltar el loop de noche.
# Haiku solo orquesta (poco token); el código pesado lo escribe el Gemini CLI gratis.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# LEGACY: la usaba el viejo cerebro flash (gemini-2.5-flash free tier), ya jubilado por
# topar 429. El obrero Gemini CLI NO la usa (corre con OAuth y la quita con `env -u`).
# Puedes dejarla vacía o borrar esta línea.
GEMINI_API_KEY=your_free_tier_gemini_api_key_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
OPENCLAW_PASSWORD=sandbox

# --- Git: para que Naru pueda commitear/pushear a GitHub desde el contenedor ---
# PAT de GitHub con permiso de escritura sobre el repo night-coding. Idealmente un
# fine-grained token limitado SOLO a Gozhack/night-coding (Contents: Read/Write).
# Sin esto, Naru puede commitear local pero NO pushear (y no se dispara el deploy).
GITHUB_TOKEN=ghp_your_personal_access_token_here
# Identidad con la que el bot firma sus commits (opcional, tiene defaults).
GIT_USER_NAME=Naru
GIT_USER_EMAIL=naru@night-coding.local
