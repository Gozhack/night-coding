; Engine configuration file.
; Void-Tap — proyecto Godot independiente (un juego = un proyecto).
; El hub (web-hub/) y el deploy son compartidos; este project.godot es solo de void-tap.

config_version=5

[application]

config/name="Void-Tap"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "gl_compatibility")

[autoload]

VoidGameManager="*res://scripts/GameManager.gd"
AudioManager="*res://scripts/AudioManager.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
